{
    "compilerOptions": {
        "module": "esnext",
        "moduleResolution": "Bundler",
        "target": "ES2024",
        "jsx": "react-jsx",
        "checkJs": false,
        "experimentalDecorators": false,
        "strictNullChecks": true,
        "strictFunctionTypes": true,
        "strict": true,
        "sourceMap": true,
        "allowImportingTsExtensions": true,
        "noEmit": true,
        "verbatimModuleSyntax": true
    },
    "exclude": [
        "node_modules",
        "**/node_modules/*"
    ]
}